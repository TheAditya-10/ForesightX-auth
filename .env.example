SERVICE_NAME=foresightx-auth
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8004

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/foresightx_auth
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8004/oauth/google/callback
PROFILE_SERVICE_URL=http://localhost:8002
PROFILE_CREATE_PATH=/profiles
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=INFO
